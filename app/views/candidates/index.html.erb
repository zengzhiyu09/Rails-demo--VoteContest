<div class="container mt-4">
  <!-- 1. 顶部导航栏 -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">
      Hong Kong Beauty Contest - Page <%= @current_page %>/<%= @total_pages %>
    </h3>
    <div>
      <%= link_to "Update Phone Number", edit_user_registration_path, class: "me-3" %>
      <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete } %>
    </div>
  </div>

  <!-- 2. 候选人列表循环 -->
  <% @candidates.each do |candidate| %>
    <div class="card mb-4 shadow-sm">
      <div class="card-body">
        <div class="row">
          <!-- 左侧：文字信息 -->
          <div class="col-md-4">
            <h5 class="card-title"><%= candidate.name %></h5>
            <h6 class="card-subtitle mb-2 text-muted"><%= candidate.age %></h6>
            <!-- 视频链接文本 (Requirement #3) -->
            <p class="small text-break mb-3">
              <%= candidate.video_url %>
            </p>
            <p class="card-text"><%= candidate.backstory %></p>

            <!-- 投票按钮区域 -->
            <div class="mt-3">
              <% if session[:voted_candidate_id] && session[:voted_candidate_id] != candidate.id %>
                <!-- 情况 A: 已投给别人，当前候选人按钮隐藏 (Requirement #4) -->
              <% elsif session[:voted_candidate_id] == candidate.id %>
                <!-- 情况 B: 已投给当前候选人，显示 VOTED (Requirement #4) -->
                <%= button_to "VOTED FOR #{candidate.name.upcase}",
                              vote_candidate_path(candidate),
                              method: :post,
                              disabled: true,
                              class: "btn btn-secondary btn-sm" %>
              <% else %>
                <!-- 情况 C: 尚未投票，显示可点击按钮 -->
                <%= button_to "VOTE FOR #{candidate.name.upcase}",
                              vote_candidate_path(candidate),
                              method: :post,
                              class: "btn btn-primary btn-sm" %>
              <% end %>
            </div>
          </div>

          <!-- 右侧：图片网格 (Requirement #3 - 12 placeholders) -->
          <div class="col-md-8">
            <div class="row g-1">
              <% 12.times do |i| %>
                <div class="col-4">
                  <!-- 使用占位图，尺寸设为 150x100 -->
                  <img src="https://picsum.photos/seed/<%= candidate.id + i %>/150/100"
                       class="img-fluid rounded border"
                       style="height: 80px; width: 100%; object-fit: cover; cursor: pointer;"
                       alt="Photo"
                       onclick="alert('Photo enlarged')"> <!-- Requirement #3: Click to enlarge -->
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
      <!-- 底部水平分割线 (Requirement #3) -->
      <hr class="m-0">
    </div>
  <% end %>

  <!-- 3. 分页导航 (Requirement #3 - Bottom of page) -->
  <nav aria-label="Page navigation" class="d-flex justify-content-center">
    <ul class="pagination">
      <!-- 上一页按钮 -->
      <% if @current_page > 1 %>
        <li class="page-item">
          <%= link_to "< PREVIOUS PAGE", candidates_path(page: @current_page - 1), class: "page-link" %>
        </li>
      <% end %>

      <!-- 页码数字 (1 2 3 4 5) -->
      <% @total_pages.times do |i| %>
        <% page_num = i + 1 %>
        <li class="page-item <%= 'active' if page_num == @current_page %>">
          <%= link_to page_num, candidates_path(page: page_num), class: "page-link" %>
        </li>
      <% end %>

      <!-- 下一页按钮 -->
      <% if @current_page < @total_pages %>
        <li class="page-item">
          <%= link_to "NEXT PAGE >", candidates_path(page: @current_page + 1), class: "page-link" %>
        </li>
      <% end %>
    </ul>
  </nav>
</div>